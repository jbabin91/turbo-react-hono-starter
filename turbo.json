{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["NODE_ENV", "DATABASE_URL", "PROD"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!CHANGELOG.md",
        "!eslint.config.js",
        "!playwright.config.ts",
        "!e2e/**",
        "!.env.example",
        ".env*"
      ],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:reset": {},
    "db:seed": {},
    "db:studio": {},
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "!CHANGELOG.md"],
      "outputs": ["node_modules/.cache/.eslintcache"]
    },
    "preview": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": ["node_modules/.cache/*.tsbuildinfo"]
    }
  }
}
