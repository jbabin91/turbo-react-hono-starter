    "lint": "eslint .",
    "preview": "pnpm build && node dist/index.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.2",
    "@hono/zod-openapi": "^0.14.2",
    "@repo/api": "workspace:*",
    "@repo/configs": "workspace:*",
    "hono": "^4.4.5"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "tsup": "^8.1.0",
    "tsx": "^4.15.4"
  }
}
